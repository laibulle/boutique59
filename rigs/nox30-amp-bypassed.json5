{
  // Diagnostic rig: the amp is bypassed, so the file input feeds the cab/IR path
  // directly when an IR is enabled from the CLI.
  name: 'nox30-amp-bypassed',

  chain: {
    cable_capacitance_pf: 470,
  },

  amp: {
    model: 'nox30',
    bypassed: true,
    controls: {
      volume: 0.76,
      bass: 0.52,
      treble: 0.61,
      cut: 0.47,
      drive: 0.68,
      presence: 0.44,
      sag: 0.70,
    },
  },
}
